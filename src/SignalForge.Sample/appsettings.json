{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=SignalForge;Username=postgres;Password=postgres"
  },
  "SignalForge": {
    "HubPath": "/hubs/chat",
    "EnableDetailedErrors": true,
    "EnableActivityLogging": true,
    "EnableRequestLogging": true
  }
}
